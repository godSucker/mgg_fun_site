---
export const prerender = true

import BaseLayout from '@/layouts/BaseLayout.astro'
import TierList from '@/components/TierList.svelte'
import mutants from '@/data/mutants/mutants.json'
import * as fs from 'node:fs'
import * as XLSX from 'xlsx'

const xlsxBuf = fs.readFileSync('src/data/mut_tier.xlsx')
const wb = XLSX.read(xlsxBuf, { type: 'buffer' })
const ws = wb.Sheets[wb.SheetNames[0]]
const rows = XLSX.utils.sheet_to_json(ws, { header: 1 }) as any[][]

const tierMap: Record<string, string> = {
  '1_': '1+', '1__': '1', '1___': '1-',
  '2_': '2+', '2__': '2', '2___': '2-',
  '3_': '3+', '3__': '3', '3___': '3-',
  '4_': '4',
}

function normalize(s: string): string {
  return s.toLowerCase().replace(/[^a-zа-яё0-9]/g, '').trim()
}

const nameToTier = new Map<string, string>()
for (const row of rows) {
  const name = row[1]
  const rawTier = row[4]
  if (name && rawTier && typeof name === 'string') {
    const trimmed = String(rawTier).trim()
    const mapped = tierMap[trimmed]
    if (mapped) {
      nameToTier.set(normalize(name), mapped)
    }
  }
}

const tieredMutants = (mutants as any[])
  .filter(m => {
    if (!m.name) return false
    const tier = nameToTier.get(normalize(m.name))
    if (tier) {
      m.tier = tier
      return true
    }
    return false
  })
---

<BaseLayout title="Тир-лист — Archivist-Library" fullWidth>
  <div class="mb-6 text-center">
    <h1 class="text-2xl sm:text-3xl font-extrabold text-white tracking-wide mb-2">
      Тир-лист лучших мутантов в PvP
    </h1>
    <p class="text-sm text-slate-300">
      Актуально на февраль 2026. Мутанты расположены по генам от Киборга до Мифика.
    </p>
  </div>

  <TierList client:load mutants={tieredMutants} />

  <p class="mt-8 text-xs sm:text-sm text-slate-300 leading-relaxed text-center max-w-3xl mx-auto">
    Напоминаем, что этот топ является субъективным виденьем меты игры админами группы. У нас есть неплохой игровой опыт и примерное понимание меты. Однако, в тире всегда могут быть неточности, всем людям не сойтись на одном мнении. Тир создан для примерного понимания силы мутантов и упрощенного восприятия общей картины игрового баланса.
  </p>
</BaseLayout>
