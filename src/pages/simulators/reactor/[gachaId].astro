---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ReactorSimulator from '../../../components/simulators/reactor/ReactorSimulator.svelte';
import { getGachaMeta, listGachas } from '../../../lib/reactor-gacha';
import { getMutantTexture, getSkinTextures } from '../../../lib/mutant-textures';
import fs from 'node:fs';
import path from 'node:path';

export const prerender = true;

interface Props {
  gacha: ReturnType<typeof getGachaMeta> extends infer T ? Exclude<T, null> : never;
  baseTextures: Record<string, string | null>;
  completionTexture: string | null;
}

export function getStaticPaths() {
  // Апгрейд текстуры награды до FULL-версии (полный рост вместо головы/полу-роста).
  // Работает на этапе сборки: берём FULL-файл только если он реально лежит в public/
  // (public/ синкается на CDN, так что локальное наличие = наличие на CDN).
  // NB: хелпер живёт внутри getStaticPaths — Astro исполняет её изолированно
  // и не видит переменные фронтматтера снаружи.
  const PUB = path.join(process.cwd(), 'public');
  const exists = (rel: string) => fs.existsSync(path.join(PUB, rel.replace(/^\//, '')));

  function upgradeToFull(specimenId: string, texture: string | null): string | null {
    const code = String(specimenId)
      .replace(/^Specimen_/i, '')
      .toLowerCase();

    // 1) FULL-версия скина: semi-full/specimen_<code>_<skin>.webp -> full/FULL_<code>_<skin>.png
    if (texture) {
      const m = texture.match(/\/semi-full\/specimen_(.+)\.webp$/);
      if (m) {
        const full = `/textures_by_skins/textures_by_skin/full/FULL_${m[1]}.png`;
        if (exists(full)) return full;
      }
      // уже full/ (chess) — оставляем как есть
      if (texture.includes('/full/FULL_')) return texture;
    }

    // 2) FULL-версия самого мутанта
    const mutantFull = `/textures_by_mutant/${code}/FULL_${code}.png`;
    if (exists(mutantFull)) return mutantFull;

    return texture;
  }

  return listGachas()
    .filter((gacha): gacha is NonNullable<typeof gacha> => gacha !== null)
    .map((gacha) => {
      const baseIds = gacha.basic_elements.map((reward) => reward.specimen);
      const baseTextures = getSkinTextures(baseIds);
      for (const id of baseIds) {
        baseTextures[id] = upgradeToFull(id, baseTextures[id]);
      }
      const completionTexture = gacha.completion_reward
        ? upgradeToFull(
            gacha.completion_reward.specimen,
            getMutantTexture(gacha.completion_reward.specimen),
          )
        : null;

      return {
        params: { gachaId: gacha.id },
        props: { gacha, baseTextures, completionTexture },
      };
    });
}

const { gacha, baseTextures, completionTexture } = Astro.props as Props;
---

<BaseLayout
  title={`Реактор — ${gacha.name}`}
  fullWidth
  viewport="width=device-width, initial-scale=1"
>
  <!-- Главная обертка с защитой от горизонтальной прокрутки всего сайта -->
  <div class="page-wrapper">
    <div class="nav-header">
      <a class="back-link" href="/simulators/reactor">
        <span class="arrow">←</span> НАЗАД
      </a>
    </div>

    <!-- Враппер для компонента -->
    <div class="component-container">
      <ReactorSimulator
        client:load
        gachaId={gacha.id}
        gacha={gacha}
        baseTextures={baseTextures}
        completionTexture={completionTexture}
      />
    </div>
  </div>
</BaseLayout>

<style>
  /*
     1. Защита хедера/футера от обрезания.
     overflow-x: hidden гарантирует, что если контент внутри шире экрана,
     он не растянет тег <body> и не сломает верстку сайта.
  */
  .page-wrapper {
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    padding: 1rem 0.5rem;
    box-sizing: border-box;
  }

  /* Центровка для больших экранов */
  @media (min-width: 1200px) {
    .page-wrapper {
      max-width: 1200px;
      margin: 0 auto;
      overflow-x: hidden;
    }
  }

  .nav-header {
    margin-bottom: 1rem;
    padding-left: 0.5rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #93c5fd;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.5rem 0;
  }

  .back-link:hover {
    color: #fff;
  }

  .component-container {
    width: 100%;
  }

  /*
     2. Глобальный фикс ТОЛЬКО для заголовков.
     Картинки (img) я отсюда убрал, чтобы они не ломались.
     Лечим только текст, чтобы он переносился и не растягивал контейнер.
  */
  .component-container :global(h1) {
    white-space: normal !important;
    overflow-wrap: break-word !important;
    font-size: clamp(1.5rem, 6vw, 2.2rem) !important;
    line-height: 1.2 !important;
  }

  /* Разрешаем шапке складываться */
  .component-container :global(.stage-header) {
    flex-wrap: wrap !important;
  }
</style>
