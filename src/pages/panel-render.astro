---
import StatsCalculator from '../components/StatsCalculator.svelte';

const stateParam = Astro.url.searchParams.get('state') || '{}';
---

<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <link rel="preload" as="font" type="font/woff2" href="https://cdn.archivist-library.com/fonts/tt-supermolot-neue/TTSupermolotNeue-Bold.woff2" crossorigin />
  <link rel="stylesheet" href="https://cdn.archivist-library.com/fonts/tt-supermolot-neue/tt-supermolot-neue.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #0d1117; font-family: "TT Supermolot Neue", ui-sans-serif, system-ui, sans-serif; font-weight: 700; }
    .wrap { padding: 16px; display: flex; justify-content: center; }
  </style>
</head>
<body>
  <div class="wrap">
    <StatsCalculator client:only="svelte" renderState={stateParam} />
  </div>
</body>
</html>
